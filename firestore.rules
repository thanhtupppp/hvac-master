rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Hàm kiểm tra quyền Admin
    function isAdmin() {
      return request.auth != null && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Collection "admins": Chỉ cấp quyền đọc cho chính người đó hoặc admin khác. Không cho phép GHI từ client.
    match /admins/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow write: if false; // Chỉ thêm admin qua giao diện Firebase Console hoặc Admin SDK
    }

    // Collection "users": Người dùng đọc được doc của chính mình,
    // nhưng KHÔNG được sửa entitlement fields — chỉ Admin SDK (webhook/api) được ghi.
    //
    // Entitlement fields: isPremium, premiumExpiry, activeSubscriptionId, isPremiumOverride
    // Attack: client ghi isPremium: true, premiumExpiry: <far_future> → VIP miễn phí.
    match /users/{userId} {
      // Ai cũng đọc (cần hiển thị profile), nhưng user chỉ đọc được doc của mình.
      allow read: if request.auth != null;

      // User được tạo doc của chính mình (first-login auto-create).
      // Entitlement fields bị chặn để ngăn tự cấp VIP.
      allow create: if request.auth.uid == userId
        && !request.resource.data.diff({}).affectedKeys()
          .hasAny(["isPremium", "premiumExpiry", "activeSubscriptionId", "isPremiumOverride"]);

      // User được xoá doc của chính mình (deleteAccount).
      allow delete: if request.auth.uid == userId;

      // Update: user sửa được doc của mình nhưng KHÔNG được sửa entitlement fields.
      allow update: if request.auth.uid == userId
        && (
          !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(["isPremium", "premiumExpiry", "activeSubscriptionId", "isPremiumOverride"])
          || isAdmin()
        );

      // Subcollections (bookmarks, etc.)
      match /{document=**} {
        allow read, write: if request.auth != null
          && (request.auth.uid == userId || isAdmin());
      }
    }

    // Collection "articles": Bài viết công khai và premium.
    // Premium content: bài viết có field `premium: true` chỉ user có VIP mới đọc được.
    // Ai cũng có thể đọc bài viết công khai.
    match /articles/{articleId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Subcollection "articles/{id}/premium_content": Chỉ user có VIP mới đọc được.
    // Admin vẫn đọc/ghi được để quản lý nội dung.
    match /articles/{articleId}/premium_content/{docId} {
      allow read: if request.auth != null
        && (isAdmin()
            || (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isPremium == true
                && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status != "disabled"));
      allow write: if isAdmin();
    }
    
    // Collection "categories": Danh mục bài viết
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Collection "brands": Hãng sản xuất thiết bị
    match /brands/{brandId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Collection "search_queries": Lưu trữ từ khóa tìm kiếm phổ biến
    // Đọc công khai để suggest, chỉ admin mới được ghi
    match /search_queries/{queryId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
