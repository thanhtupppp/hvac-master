rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Hàm kiểm tra quyền Admin
    function isAdmin() {
      return request.auth != null && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Collection "admins": Chỉ cấp quyền đọc cho chính người đó hoặc admin khác. Không cho phép GHI từ client.
    match /admins/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow write: if false; // Chỉ thêm admin qua giao diện Firebase Console hoặc Admin SDK
    }

    // Collection "users": Người dùng đọc được doc của chính mình,
    // nhưng KHÔNG được sửa entitlement fields và status — chỉ Admin SDK (webhook/api) được ghi.
    //
    // Entitlement fields: isPremium, premiumExpiry, activeSubscriptionId, isPremiumOverride
    // Server-managed field: status
    // Client-allowed fields: displayName, photoURL, updatedAt
    //
    // Attack vectors:
    // - Client ghi isPremium: true, premiumExpiry: <far_future> → VIP miễn phí.
    // - Client ghi status: 'active' → bỏ qua khóa tài khoản từ admin.
    match /users/{userId} {
      // Ai cũng đọc (cần hiển thị profile), nhưng user chỉ đọc được doc của mình.
      allow read: if request.auth != null;

      // User được tạo doc của chính mình (first-login auto-create).
      // Chặn: isPremium: true, premiumExpiry, activeSubscriptionId, isPremiumOverride.
      // Cho phép: isPremium: false (default) và mọi trường hợp không chứa entitlement keys.
      // Kiểm tra: nếu isPremium được gửi kèm, nó phải là false — nếu là true thì bị chặn bởi
      // giá trị kiểm tra cuối cùng (isPremium != true).
      allow create: if request.auth.uid == userId
        && (
          // Case A: payload không chứa bất kỳ entitlement key nào → cho phép
          !request.resource.data.diff({}).affectedKeys()
            .hasAny(["isPremium", "premiumExpiry", "activeSubscriptionId", "isPremiumOverride"])
          // Case B: payload có isPremium nhưng giá trị không phải true (tức là false)
          // Kết hợp với kiểm tra hasAny ở trên đảm bảo các entitlement key khác không có mặt
          || request.resource.data.isPremium == false
        );

      // User được xoá doc của chính mình (deleteAccount).
      // Chuyển việc xóa thực sự sang /api/profile/delete (Admin SDK)
      // để đảm bảo xóa đầy đủ subcollections + Auth account.
      allow delete: if request.auth.uid == userId;

      // Update: user chỉ được sửa displayName, photoURL, updatedAt.
      // Mọi thay đổi entitlement hoặc status chỉ được thực hiện bởi Admin SDK.
      allow update: if request.auth.uid == userId
        && (
          // Client được sửa: displayName, photoURL, updatedAt
          !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(["isPremium", "premiumExpiry", "activeSubscriptionId", "isPremiumOverride", "status"])
          || isAdmin()
        );

      // Subcollections (bookmarks, etc.)
      match /{document=**} {
        allow read, write: if request.auth != null
          && (request.auth.uid == userId || isAdmin());
      }
    }

    // Collection "articles": Bài viết công khai và premium.
    // Premium content: bài viết có field `premium: true` chỉ user có VIP mới đọc được.
    // Ai cũng có thể đọc bài viết công khai.
    match /articles/{articleId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Subcollection "articles/{id}/premium_content": Chỉ user có VIP mới đọc được.
    // Admin vẫn đọc/ghi được để quản lý nội dung.
    match /articles/{articleId}/premium_content/{docId} {
      allow read: if request.auth != null
        && (isAdmin()
            || (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isPremium == true
                && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status != "disabled"));
      allow write: if isAdmin();
    }
    
    // Collection "categories": Danh mục bài viết
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Collection "brands": Hãng sản xuất thiết bị
    match /brands/{brandId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Collection "search_queries": Lưu trữ từ khóa tìm kiếm phổ biến
    // Đọc công khai để suggest, chỉ admin mới được ghi
    match /search_queries/{queryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Collection "subscription_plans": Cấu hình gói VIP hiển thị trên paywall.
    // Mobile đọc PUBLIC để hiển thị. Tất cả write chỉ qua Admin SDK
    // (đã có /api/plans CRUD dùng Admin SDK).
    match /subscription_plans/{planId} {
      allow read: if true;
      allow write: if false; // chỉ Admin SDK / Cloud Function
    }
  }
}
