rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Hàm kiểm tra quyền Admin
    function isAdmin() {
      return request.auth != null && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Collection "admins": Chỉ cấp quyền đọc cho chính người đó hoặc admin khác. Không cho phép GHI từ client.
    match /admins/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow write: if false; // Chỉ thêm admin qua giao diện Firebase Console hoặc Admin SDK
    }

    // Collection "users": Quản lý thông tin người dùng và các subcollections (như bookmarks)
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    // Collection "articles": Quản lý bài viết (Hướng dẫn, mã lỗi...)
    match /articles/{articleId} {
      // Cho phép đọc công khai (VIP/Premium sẽ được kiểm soát ở giao diện client)
      allow read: if true;
      
      // Chỉ Admin mới được thêm/sửa/xóa bài viết
      allow create, update, delete: if isAdmin();
    }
    
    // Collection "categories": Danh mục bài viết
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Collection "brands": Hãng sản xuất thiết bị
    match /brands/{brandId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Collection "search_queries": Lưu trữ từ khóa tìm kiếm phổ biến
    // Đọc công khai để suggest, chỉ admin mới được ghi
    match /search_queries/{queryId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
